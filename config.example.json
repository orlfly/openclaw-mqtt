{
  "channels": {
    "mqtt": {
      "brokerUrl": "mqtt://localhost:1883",
      "username": "your-username",
      "password": "YOUR_PASSWORD_HERE",
      "clientId": "openclaw-agent",
      "protocolVersion": 5,
      "userProperties": {
        "application": "openclaw-mqtt",
        "version": "1.0.0"
      },
      "topics": {
        "inbound": "openclaw/inbound",
        "outbound": "openclaw/outbound"
      },
      "qos": 1,
      "tls": {
        "enabled": false
      }
    }
  }
}
